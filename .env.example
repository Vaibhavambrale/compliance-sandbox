# Supabase — project URL and keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Anthropic — used for report generation AND semantic-metric LLM-as-judge
# Programmatic scoring still primary (deterministic); semantic is additive
ANTHROPIC_API_KEY=sk-ant-...your-key

# Judge configuration (semantic metrics — bias, toxicity, hallucination, PII)
# Set JUDGE_MAX_CALLS_PER_RUN=0 to disable the semantic layer entirely
JUDGE_MODEL=claude-haiku-4-5-20251001
JUDGE_TEMPERATURE=0
JUDGE_MAX_CALLS_PER_RUN=250
